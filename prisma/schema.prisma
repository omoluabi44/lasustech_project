// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model MissionVision {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  category    String
  date        String
  desc        String
  imgUrl      String
  content     String?
  isPast      Boolean   @default(false)
  likes       Int       @default(0)
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model StudentSpotlight {
  id          Int      @id @default(autoincrement())
  name        String
  talent      String
  quote       String
  imgUrl      String
  content     String?
  likes       Int       @default(0)
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Executive {
  id          Int      @id @default(autoincrement())
  name        String
  role        String
  imgUrl      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WelfareInitiative {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imgUrl      String
  content     String?
  likes       Int       @default(0)
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Comment {
  id          Int      @id @default(autoincrement())
  authorName  String
  text        String
  createdAt   DateTime @default(now())

  eventId     Int?
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  spotlightId Int?
  spotlight   StudentSpotlight? @relation(fields: [spotlightId], references: [id], onDelete: Cascade)

  welfareId   Int?
  welfare     WelfareInitiative? @relation(fields: [welfareId], references: [id], onDelete: Cascade)
}
